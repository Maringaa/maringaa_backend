# ==============================================================================
# MARINGA BACKEND CONFIGURATION (.env.example)
# ==============================================================================

# Server configuration
PORT=3001
CORS_ORIGIN=*

# JWT Auth
JWT_SECRET=super_secret_jwt_key_for_maringa_change_in_production
JWT_EXPIRATION=900s

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=maringa_user
DB_PASSWORD=maringa_password
DB_DATABASE=maringa_dev
DB_SYNCHRONIZE=true

# Cache Configuration (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# Event Bus Configuration (RabbitMQ)
RABBITMQ_URL=amqp://maringa_guest:maringa_password@localhost:5672
RABBITMQ_QUEUE=maringa_events_queue

# Stellar / Soroban Configuration
STELLAR_NETWORK=standalone
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
STELLAR_RPC_URL=http://localhost:8000/soroban/rpc
STELLAR_HORIZON_URL=http://localhost:8000

# Administrative / Settlement Custody Accounts (G... & S... keys)
# Generate keypairs locally using `stellar keys generate`
STELLAR_TREASURY_SECRET_KEY=SCMOCKSECRETKEYDONTCOMMITINPRODUCTION...
STELLAR_SETTLEMENT_SECRET_KEY=SCMOCKSECRETKEYDONTCOMMITINPRODUCTION...
